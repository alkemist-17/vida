
//
// Test Suite
// Global and local asignments
//


let message = "Global asignment test failure"
let localShadowMessage = "Local shadow asignment test failure"
let blockLocalMessage = "Block local variable failure"

let v1 = 21
assert(v1 == 21, message)

let v2 = v1
assert(v2 == 21 and v1 == 21 and v1 == v2, message)

let v3 = v2
assert(v3 == v2 and v2 == v1 and v3 == v1 and v1 == 21, message)

v1 = v1 + 2
assert(v1 == 23 and v2 == 21 and v3 == v2, message)

v2 = v2 + 2
assert(v2 == v1 and v1 == 23 and v2 != v3, message)

v3 = v3
assert(v3 == v2 - 2 and v3 == v1 - 2, message)

v1 = 52
assert(v1 == 52 and v1 == v1 and v1 != v2, message)

v1 = "global asignment"
assert(v1 == "global asignment", localShadowMessage)

v2 = v1
assert(v1 == "global asignment" and v2 == "global asignment", localShadowMessage)

v3 = v2
assert(v1 == "global asignment" and v2 == "global asignment" and v2 == "global asignment", localShadowMessage)

v2 = 42
assert(v2 == 42, localShadowMessage)

{
    v2 = 100
    assert(v2 == 100, blockLocalMessage)
    {
        v2 = blockLocalMessage
        assert(v2 == blockLocalMessage, blockLocalMessage)
        {
            assert(v2 == blockLocalMessage, blockLocalMessage)
            let unknown = 1200
        }
    }
    assert(v2 == blockLocalMessage, blockLocalMessage)
}

assert(v2 == blockLocalMessage, localShadowMessage)

assert(unknown == 1200, message)

// Multiple declarations with one expression

let theMessage = "This is a test of multiple single asignments"

let jan, feb, mar, abr = theMessage, theMessage, theMessage, theMessage

assert(jan == theMessage and feb == theMessage and mar == theMessage and abr == theMessage)

jan = 42; feb = 42; mar = 42; abr = 42

var may, jun, jul, aug, sep = theMessage, theMessage, theMessage, theMessage, theMessage

assert(jan == 42 and feb == 42 and mar == 42 and abr == 42)

assert(may == theMessage and jun == theMessage and jul == theMessage and aug == theMessage and sep == theMessage)

may = 1200; jun = 1200; jul = 1200; aug = 1200; sep = 1200;

assert(may == 1200 and jun == 1200 and jul == 1200 and aug == 1200 and sep == 1200)

// Canonical swap. If eval were left-to-right instead of parallel,
// this would print 20, 20 instead of 20, 10.

let a, b, c = 10, 20, nil

assert(a == 10 and b == 20)

a, b = b, a

assert(a == 20 and b == 10)

// Same swap, but as locals inside a function body, so it exercises
// the rLoc branch of MultipleMut (register-to-register) rather than

let run = fun {
	var la, lb = 10, 20
	la, lb = lb, la
	ret [la, lb]
}

let result = run()
assert(result[0] == 20)
assert(result[1] == 10)


// Rotate three variables: a<-c, b<-a, c<-b, all using the *old* values.
// This only works correctly if every RHS is captured before any target
// is overwritten -- a pure left-to-right rewrite would corrupt this.

a, b, c = 1, 2, 3
a, b, c = c, a, b

assert(a == 3)
assert(b == 1)
assert(c == 2)


// Baseline sanity check: declaration sugar with mismatched types per
// slot and a mix of let/var, unrelated to the swap/parallel-eval story.

a, b, c = 1, "two", true
assert(a == 1)
assert(b == "two")
assert(c == true)

run = fun {
	var x, y = 3.5, [1, 2, 3]
	ret [x, y[1]]
}

result = run()

assert(result[0] == 3.5)
assert(result[1] == 2)


// `rec` + multi-decl: self-recursion works fine, because each identifier
// is registered as a local *before* its own initializer is compiled.
//
// KNOWN LIMITATION (documented, not a bug to silently paper over):
// mutual recursion between siblings in the SAME declaration does NOT
// work, because sibling N+1 isn't registered as a local until the
// compiler reaches it -- so sibling N's initializer can't see it yet.
// Compare this to the swap MultipleMut case, where all identifiers
// already exist beforehand, so no such ordering issue applies there.
// This is a decl-only quirk, inherent to "define as you go" scoping.

var rec fact, unused = fun n {
	if n < 2 { ret 1 }
	ret n * fact(n - 1)
}, 0

assert(fact(5) == 120)

// The following, if uncommented, is expected to FAIL to compile with
// "reference 'isOdd' not found", because isOdd doesn't exist yet at
// the point isEven's body is compiled:
//
// var rec isEven, isOdd = fun n {
// 	if n == 0 { ret true }
// 	ret isOdd(n - 1)
// }, fun n {
// 	if n == 0 { ret false }
// 	ret isEven(n - 1)
// }
//
// Workaround: declare placeholders first, then assign function bodies
// via ordinary (non-recursive) mutation, e.g.:
//
let isEven, isOdd = nil, nil
isEven = fun n { if n == 0 { ret true } ret isOdd(n - 1) }
isOdd = fun n { if n == 0 { ret false } ret isEven(n - 1) }

assert(isEven(5) == false)
assert(isOdd(6) == false)
assert(isEven(6) == true)
assert(isOdd(5) == true)


// Swaps two locals from inside a nested closure, where they're
// captured as free variables rather than plain locals of the closure
// itself. This exercises MultipleMut's rFree destination branch
// (emitStore ... storeFromFree), which the plain global/local swap
// tests above never touch.

run = fun {
	var la, lb = 1, 2
	var swap = fun {
		la, lb = lb, la
        ret [la, lb]
	}
	ret swap()
}

result = run()
assert(result[0] == 2)
assert(result[1] == 1)



// Parallel assignment means "capture everything before writing
// anything" -- it does NOT mean RHS expressions run out of order or
// more than once. This test proves each RHS runs exactly once, in
// left-to-right source order, via a logged side effect.

let tag = fun label, value {
	assert(label == "first" or label == "second") // fires as a side effect at evaluation time
	ret value
}

a, b = 100, 200
a, b = tag("first", b), tag("second", a)

// Expected full output, in order:
//   first
//   second
//   200
//   100
// If "first"/"second" print more than once, out of order, or the
// final values are wrong, evaluation isn't both single-pass and
// left-to-right.

assert(a == 200)
assert(b == 100)


// Nothing says both targets of a multi-mutation have to live in the
// same scope. Confirms MultipleMut resolves each identifier
// independently via refScope rather than assuming a single scope for
// the whole statement.

let g = 1

run = fun {
	var l = 2
	g, l = l, g
	ret l
}

let localResult = run()
assert(g == 2)
assert(localResult == 1)







// Baseline for indexed targets: swap two elements of the same array.
// Exercises the fresh compiler path (container+key captured into
// scratch registers) for the first time against a real reference type.

let A = [10, 20, 30]
A[0], A[1] = A[1], A[0]

assert(A[0] == 20)
assert(A[1] == 10)
assert(A[2] == 30)




// Same idea, but for object properties -- exercises the
// Selectable/Selector branch of target address resolution rather than
// Indexable/Index.

let o = { x = 1, y = 2 }
o.x, o.y = o.y, o.x

assert(o.x == 2)
assert(o.y == 1)



// The exact case that drove the current design decision: `i` is
// both an index INTO a target and a target itself in the same
// statement. A[i]'s address must be resolved using the OLD i,
// regardless of where `i` sits in the target list.

A = [100, 200, 300]
var i = 0

A[i], i = 999, 2

assert(A[0] == 999) // expect: 999  (old i=0 was the write location)
assert(A[1] == 200) // expect: 200  (untouched)
assert(i == 2)      // expect: 2 after assignment






// Same logical statement, but with
// the target list REORDERED (i first, then A[i]). Under true parallel
// semantics this must produce IDENTICAL results to 11 -- this is
// exactly the guarantee Python/JS/Ruby do NOT provide (their behavior
// would differ here based on order), and the reason the design decision was
// chosen for Vida.

A = [100, 200, 300]
i = 0

i, A[i] = 2, 999

assert(A[0] == 999) // expect: 999  (same as the past test, despite reordering)
assert(A[1] == 200) // expect: 200
assert(i == 2)      // expect: 2





// A[0][1] as a target: Indexable itself is a nested IGet (A[0]), not
// a bare Reference. Confirms compileExpr's existing nested-IGet
// handling works correctly when reused for address resolution rather
// than value resolution.

A = [[1, 2], [3, 4]]
let x = 999

A[0][1], x = x, A[0][1]

assert(A[0][0] == 1)   // expect: 1   (untouched)
assert(A[0][1] == 999) // expect: 999
assert(A[1][0] == 3)   // expect: 3   (untouched)
assert(A[1][1] == 4)   // expect: 4   (untouched)
assert(x == 2)         // expect: 2   (old A[0][1] value)






// A, B = B, A on variables holding arrays swaps which NAME points to
// which array -- it does not copy array contents. Mutating through
// one name after the swap must be visible through whichever name now
// points at the same underlying array (reference semantics).

A = [1, 2, 3]
let B = [9, 8, 7]

A, B = B, A

assert(A[0] == 9) // expect: 9  (A now refers to the old B array)
assert(B[0] == 1) // expect: 1  (B now refers to the old A array)

// Mutate through A -- since A now points at the array [9, 8, 7],
// and nothing else aliases that specific array object, this should
// NOT affect B.
A[0] = 111

assert(A[0] == 111) // expect: 111
assert(B[0] == 1)   // expect: 1 (unaffected -- confirms A and B point at
                   //            genuinely distinct array objects post-swap,
                   //            the swap moved references, it didn't merge them)








// Sharper version of the past test: C aliases the SAME array as A before the
// swap. After A, B = B, A, the swap only rebinds what A and B point
// to -- it can't have "followed" C, since C was never a target. C
// should still point at whatever array it always pointed at,
// regardless of what A now refers to.

A, B = [1, 2, 3], [9, 8, 7]
let C = A // C aliases the SAME array object as A, not a copy

A, B = B, A

assert(A[0] == 9) // expect: 9   (A now refers to the old B array)
assert(C[0] == 1) // expect: 1   (C still refers to the original array,
                  //              unaffected by A's rebinding)

C[0] = 555
assert(A[0] == 9)   // expect: 9   (A's rebinding is untouched by mutating C)
assert(C[0] == 555) // expect: 555







// If target-address capture accidentally re-evaluated the index
// expression (once during "capture" and again during "write"), this
// would fire twice. It must fire exactly once, since Phase 2 captures
// the key into a scratch register and Phase 3 only ever reads that
// register back.

A = [10, 20, 30]

let calls = 0
let idx = fun {
	calls = calls + 1
	ret 1
}

x = 0
A[idx()], x = 999, 111

assert(A[1] == 999)  // expect: 999
assert(x == 111)     // expect: 111
assert(calls == 1)   // expect: 1 (not 2 -- proves Phase 2 captures the key
                     //             once into a scratch register, and Phase 3
                     //             only ever reads that register back)







// KNOWN, DOCUMENTED BEHAVIOR:
// firstDuplicateIdentTarget only catches duplicate PLAIN IDENTIFIERS
// (e.g. `a, a = 1, 2`). It can't prove A[0] and A[0] alias the same
// slot at compile time in general -- that would require full alias
// analysis, which Vida doesn't do. So this is accepted at parse time,
// and at runtime it's simply "last write wins" among targets that
// happen to collide, same as Go's spec for the analogous case.

A = [1, 2, 3]
A[0], A[0] = 111, 222

assert(A[0] == 222) // expect: 222 -- whichever target is LAST in the list
                    // wins, since Phase 3 writes execute in target order and
                    // both targets' addresses already point at the same slot






// Regression check specifically against the reference-type examples.
// None of this touches MultipleMut at all -- it's here purely to
// confirm the parser surgery in mutateDataStructureOrCallStmt didn't
// disturb the pre-existing single-target statement path.

A = [{ hello = fun -> "hi" }]
assert(A[0]::hello() == "hi")

B = [[1, 2], [2, 3]]
B[0][1] = nil
assert(B[0][1] == nil) // expect: nil
assert(B[0][0] == 1)   // expect: 1 (untouched)

o = { hello = 42, world = 55 }
o[90] = "fourteen"
o.alpha = "alpha"
assert(o.alpha == "alpha")  // expect: alpha
assert(o[90] == "fourteen") // expect: fourteen
assert(o.hello == 42)       // expect: 42





