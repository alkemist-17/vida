var bytes = load("std/bytes")

assert(
    bytes and
    bytes.new and
    bytes.from and
    bytes.genCryptoRand and
    bytes.timingSafeEqual and
    bytes.encode and
    bytes.decode and
    bytes.encoding and
    bytes.toFile and
    bytes.xor and
    bytes.toString and
    bytes.uuid and
    bytes.parseUUID and
    bytes.bitLen and
    bytes.hexdump
)



var size = 10
var init = 0xFF
var s = "This is a string test"
var u = `/this/path+/this/other/path`
var A = bytes.new(size)
var B = nil
var HEX = "54686973206973206120737472696e672074657374"
var B64 = "VGhpcyBpcyBhIHN0cmluZyB0ZXN0"
var B64URL = "L3RoaXMvcGF0aCsvdGhpcy9vdGhlci9wYXRo"
var dash = "-"


assert(len(A) == size)
for _, v in A {
    assert(v == 0)
}


A = bytes.new(size, init)
for _, v in A {
    assert(v == init)
}


A = bytes.new(s)
B = bytes.new(s)
assert(len(A) == len(B))
for i in len(A) {
    assert(A[i] == B[i])
}


A = bytes.genCryptoRand(8)
B = bytes.new(A)
assert(not(A == B))
assert(len(A) == len(B))
for i in len(A) {
    assert(A[i] == B[i])
}

assert(len(bytes.new()) == 0)
assert(len(bytes.from()) == 0)


A = [0xAA, 0xBB, nil, true, false, 0xFF]
B = bytes.new(A)
assert(len(B) == 3 and B[0] == 0xAA and B[1] == 0xBB and B[2] == 0xFF)


B = bytes.from(A)
assert(len(B) == 3 and B[0] == 0xAA and B[1] == 0xBB and B[2] == 0xFF)


B = bytes.from(s)
assert(len(B) == len(s))

A = bytes.from(B)
assert(not(A == B))
assert(len(A) == len(B))
for i in len(A) {
    assert(A[i] == B[i])
}

A = bytes.genCryptoRand(size)
B = bytes.genCryptoRand(size)

assert(
    not(bytes.timingSafeEqual(A, B)) and
    bytes.timingSafeEqual(A, A) and
    bytes.timingSafeEqual(B, B)
)


A = bytes.from(s)
B = bytes.encode(A, bytes.encoding.hex)
assert(B == HEX)


B = bytes.encode(A, bytes.encoding.base64)
assert(B == B64)


B = bytes.decode(HEX, bytes.encoding.hex)
assert(format("%s", B) == s)


B = bytes.decode(B64, bytes.encoding.base64)
assert(format("%s", B) == s)


A = bytes.from(u)
B = bytes.encode(A, bytes.encoding.base64url)
assert(B == B64URL)

assert(u == format("%s", bytes.decode(B, bytes.encoding.base64url)))

A = bytes.uuid(nil)
assert(A == "00000000-0000-0000-0000-000000000000")

A = bytes.uuid("max")
assert(A == "FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF")

A = bytes.uuid()
assert(len(A) == 36)
assert(A[8] == dash)
assert(A[13] == dash)
assert(A[18] == dash)
assert(A[23] == dash)

A = bytes.genCryptoRand(16)
B = bytes.uuid(A)
assert(len(B) == 36)
assert(B[8] == dash)
assert(B[13] == dash)
assert(B[18] == dash)
assert(B[23] == dash)

B = bytes.parseUUID(B)
assert(bytes.timingSafeEqual(A, B))


var i = "random-data"
var k = bytes.from(i)

assert(len(i) == len(k))
assert(bytes.encode(k, bytes.encoding.base64) == "cmFuZG9tLWRhdGE=")
assert(bytes.encode(k, bytes.encoding.hex) == "72616e646f6d2d64617461")
assert(bytes.encode(k, bytes.encoding.HEX) == "72616E646F6D2D64617461")
assert(bytes.encode(k, bytes.encoding.base64url) == "cmFuZG9tLWRhdGE=")
assert(bytes.encode(k, bytes.encoding.binary) == "0111001001100001011011100110010001101111011011010010110101100100011000010111010001100001")

assert(bytes.toString(bytes.decode(bytes.encode(k, bytes.encoding.base64), bytes.encoding.base64)) == i)
assert(bytes.toString(bytes.decode(bytes.encode(k, bytes.encoding.hex), bytes.encoding.hex)) == i)
assert(bytes.toString(bytes.decode(bytes.encode(k, bytes.encoding.HEX), bytes.encoding.HEX)) == i)
assert(bytes.toString(bytes.decode(bytes.encode(k, bytes.encoding.base64url), bytes.encoding.base64url)) == i)
assert(bytes.toString(bytes.decode(bytes.encode(k, bytes.encoding.binary), bytes.encoding.binary)) == i)




var encodeHex = fun b => bytes.encode(b, bytes.encoding.hex)
A = ["Marcus Aurelius", "Plato", "Aristotle", "Pythagoras", "Anaximandrus"]

var crypto = fun {
	for _, v in A {
		var i = bytes.from(v)
		var k = bytes.genCryptoRand(len(i))
		print("I =", encodeHex(i))
		print("K =", encodeHex(k))
		var c = bytes.xor(i, k)
		print("C =", encodeHex(c))
		var p = bytes.xor(c, k)
		print("P =", encodeHex(p))
        assert(bytes.timingSafeEqual(i, p))
        assert(bytes.toString(p) == v)
	}
}

crypto()


A = bytes.from("hello, world!")
B = 13*8
assert(bytes.bitLen(A) == B)

A = bytes.genCryptoRand(1024)
assert(len(A) == 1024)
print(bytes.hexdump(A))
