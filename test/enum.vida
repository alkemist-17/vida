let Planet = enum {
    mercury
    venus
    earth
    mars
    jupiter
    saturn
    uranus
    neptune
    pluton
}

assert(Planet)

assert(Planet.mercury == 0)
assert(Planet.venus == 1)
assert(Planet.earth == 2)
assert(Planet.mars == 3)
assert(Planet.neptune == 7)

let Color = enum {
    red green blue
}

assert(Color.red == 0)
assert(Color.green == 1)
assert(Color.blue == 2)

var CardSuit = enum {
    spades
    hearts
    diamonds
    clubs
}

assert(CardSuit.spades == 0)
assert(CardSuit.hearts == 1)
assert(CardSuit.diamonds == 2)
assert(CardSuit.clubs == 3)

var Konst = enum {
    c1
    c2
    c4
    c7
}

assert(Konst.c1 == 0)
assert(Konst.c2 == 1)
assert(Konst.c4 == 2)
assert(Konst.c7 == 3)

var network = { tcp udp }

var conn = { port = 3000 ntype = network.tcp }

assert(conn.ntype == network.tcp)

if conn.ntype == network.tcp {
    conn.ntype = network.udp
}

assert(conn.ntype == network.udp)

var R = enum { hello world again hello world }

assert(R.again == 2 and R.hello == 3 and R.world == 4)

