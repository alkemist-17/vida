let objType = {}.type()

let assertModule = fun module {
    assert(module and module.type() == objType and module.len() > 0)
}

let assertCache = fun dup, ext {
    assert(dup == ext and dup.type() == objType and ext.type() == objType and dup.len() == ext.len())
}

let currentFoundationExtensions = [
    "std.bytes",
    "std.time",
    "std.cast",
    "std.exception",
    "std.text",
    "std.math",
    "std.object",
    "std.array",
    "std.rand",
    "std.io",
    "std.os",
    "std.co",
    "std.json",
    "std.task",
    "std.re",
    "std.style",
    "std.http",
]

for _, v in currentFoundationExtensions {
    assertModule(load(v))
    assertCache(load(v), load(v))
}



// Test when an extension does not exists
var e = load("hello-world-42")
assert(not e and e.isError())



// Check for protected on exception
var message = "hello raised exception"
e = load("std.exception")
var raised = e::protect(e.raise, message)
assert(raised.isError() and raised.message.contains(message))

