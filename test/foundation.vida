let objType = type({})

let assertModule = fun mod {
    assert(mod and type(mod) == objType and len(mod) > 0)
}

let assertCache = fun dup, ext {
    assert(dup == ext and type(dup) == objType and type(ext) == objType and len(dup) == len(ext))
}

let currentFoundationExtensions = [
    "std/bytes",
    "std/time",
    "std/cast",
    "std/exception",
    "std/text",
    "std/math",
    "std/object",
    "std/array",
    "std/rand",
    "std/io",
    "std/os",
    "std/co",
    "std/json",
    "std/task",
    "std/re",
    "std/color",
    "std/http",
]

for _, v in currentFoundationExtensions {
    assertModule(load(v))
    assertCache(load(v), load(v))
}



// Test when an extension does not exists
var e = load("hello-world-42")
assert(not e and isError(e))



// Check for protected on exception
e = load("std/exception")
var raised = e.protected(e.raise, "hello raised exception")
assert(isError(raised) and load("std/text").contains(raised.message, "hello raised exception"))

