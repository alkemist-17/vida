var obj = load("std/object")


// The library exists and has all the expected functionality
assert(
    obj and
    obj.set and
    obj.keys and
    obj.getset and
    obj.inject and
    obj.extends and
    obj.conforms and
    obj.implements and
    obj.del and
    obj.setmeta and
    obj.getmeta and
    obj.extract and
    obj.override and
    obj.has and
    obj.values and
    obj.get and
    obj.isEmpty and
    obj.clear and
    obj.hasmeta and
    obj.delmeta and
    obj.isObject and
    obj.isCallable
)



// set, get, has and del with one value

var k = nil

var v = nil

var t = {}

var o = {}

var p = {}

var sp = {}

assert(obj.isObject(t))

assert(obj.isObject(o))

assert(obj.isObject(p))

assert(obj.isObject(sp))

assert(obj.isCallable(t) == false)

assert(obj.isCallable(o) == false)

assert(obj.isCallable(p) == false)

assert(obj.isCallable(sp) == false)

var hello = "hello"

var world = "world"

assert(o and p and sp and t)

assert(o == o and p == p and sp == sp and t == t)

assert(o != t and o != p and o != sp and p != sp and t != p)

assert(obj.isEmpty(o) and obj.isEmpty(t) and obj.isEmpty(p) and obj.isEmpty(sp))

t[o] = true

t[p] = true

t[sp] = true

obj.set(o, "hello", 42)

obj.set(o, hello, 42)

assert(not obj.isEmpty(o) and len(o) == 1)

obj.set(o, "world", obj.get(o, "hello") * 2)

obj.set(o, world, obj.get(o, hello) * 2)

assert(not obj.isEmpty(o) and len(o) == 2)

assert(obj.get(o, "hello") == 42)

assert(obj.get(o, hello) == 42)

assert(obj.get(o, "world") == 42*2)

assert(obj.get(o, world) == 42*2)

assert(obj.has(o, hello) and obj.has(o, world))

assert(obj.has(o, "hello") and obj.has(o, "world"))

obj.del(o, hello)

assert(not obj.isEmpty(o) and len(o) == 1)

obj.del(o, world)

assert(obj.isEmpty(o))



// set, get, has, clear and del with more than one value

obj.set(o, hello, 42, world, 42*2)

assert(not obj.isEmpty(o) and len(o) == 2)

assert(obj.get(o, hello) == 42 and obj.get(o, world) == 42*2)

assert(obj.has(o, hello, world))

assert(not obj.has(o, hello, world, "alpha"))

obj.del(o, hello, world)

assert(obj.isEmpty(o))

obj.set(o, hello, 42, world, 42*2)

assert(not obj.isEmpty(o) and len(o) == 2)

obj.clear(o)

assert(not obj.has(o, hello, world, "alpha"))

assert(obj.isEmpty(o))

assert(t[o] and t[p] and t[sp])



// keys, values and getset

obj.set(o, hello, 42, world, 42*2)

k = obj.keys(o)

v = obj.values(o)

assert(len(k) == 2 and type(k) == "array" and len(v) == 2 and type(v) == "array")

assert(hello in k and world in k)

assert(42 in v and 42*2 in v)

obj.clear(o)

assert(t[o] and t[p] and t[sp])

assert(obj.isEmpty(o))

obj.getset(o, hello, 42)

obj.getset(o, world, 42*2)

assert(not obj.isEmpty(o) and len(o) == 2)

assert(obj.getset(o, hello, 100) == 42)

assert(obj.getset(o, world, 200) == 42*2)

k = obj.keys(o)

v = obj.values(o)

assert(len(k) == 2 and type(k) == "array" and len(v) == 2 and type(v) == "array")

assert(hello in k and world in k)

assert(42 in v and 42*2 in v)

obj.clear(o)

assert(t[o] and t[p] and t[sp])

assert(obj.isEmpty(o))



// object prototype
// object as prototype of itself

o.__get = 42

o.__set = nil

assert(obj.hasmeta(o) == false)

obj.setmeta(o, o)

assert(obj.hasmeta(o) == true)

assert(o.hello and o[hello] and o.hello == 42 and o[hello] == 42)

assert(not obj.isEmpty(o) and len(o) == 2)

o[53] = 53

assert(o[53] == 42)

assert(not obj.isEmpty(o) and len(o) == 2)

assert(o == obj.getmeta(o) and t[obj.getmeta(o)])

obj.clear(o)

assert(t[o] and t[p] and t[sp])

assert(obj.isEmpty(o))

assert(obj.hasmeta(o) == false)

obj.setmeta(o, o)

assert(obj.hasmeta(o) == true)

assert(not o.hello and not o[hello] and o.hello == nil and o[hello] == nil)

assert(obj.isEmpty(o))

obj.delmeta(o)

assert(obj.hasmeta(o) == false)

assert(obj.isEmpty(o))

obj.clear(o)

assert(t[o] and t[p] and t[sp])

o.__get = 42

o.__set = nil

assert(o.hello and o[hello] and o.hello == 42 and o[hello] == 42)

assert(not obj.isEmpty(o) and len(o) == 2)

o[53] = 53

assert(o[53] == 42)

assert(not obj.isEmpty(o) and len(o) == 2)

obj.clear(o)

assert(t[o] and t[p] and t[sp])

o.__del = nil

o.hello = 42

assert(not obj.isEmpty(o) and len(o) == 2)

obj.del(o, hello)

assert(not obj.isEmpty(o) and len(o) == 2)

assert(o.hello == o[hello] and o.hello == 42)

obj.del(o, "__del")

assert(not obj.isEmpty(o) and len(o) == 2)

assert(o.hello == o[hello] and o.hello == 42)

obj.clear(o)

assert(t[o] and t[p] and t[sp])



// object as prototype of other objects
// prototype chain

p.hello = 42

p.world = 91

assert(obj.hasmeta(o) == false)

obj.setmeta(o, p)

assert(obj.hasmeta(o) == true)

assert(obj.isEmpty(o))

assert(o.hello == 42 and o.world == 91)

o.getHello = fun self => self.hello

assert(o:getHello() == 42)

obj.clear(o)

assert(t[o] and t[p] and t[sp])

assert(obj.isEmpty(o))

assert(obj.hasmeta(o) == false)

obj.setmeta(o, p)

assert(obj.hasmeta(o) == true)

assert(obj.isEmpty(o))

p.getHello = fun self => self.hello

p.getWorld = fun self => self.world

assert(o:getHello() == 42)

assert(o:getWorld() == 91)

obj.delmeta(o)

assert(obj.hasmeta(o) == false)

obj.clear(p)



// prototype get, set, has, del

p.__getmeta = false

p.__delmeta = false

obj.setmeta(o, p)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == false)

assert(obj.hasmeta(o))

obj.delmeta(o)

assert(obj.hasmeta(o))

obj.clear(p)

p.hello = 42

assert(o.hello == 42)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == p)

p.__setmeta = false

obj.clear(o)

obj.setmeta(o, p)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == p)

obj.setmeta(o, t)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == p)

obj.clear(p)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == p)

obj.setmeta(o, t)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == t)

obj.delmeta(o)

assert(obj.hasmeta(o) == false)

obj.clear(o)

sp.hello = fun => 42

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(o.hello() == 42)

assert(o.hello and type(o.hello) == "function")

assert(o.world == nil)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o[hello] = 42

p[world] = 91

sp.r = o + p

assert(obj.has(sp.r, hello, world))

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o.hello = 42

o.world = 91

assert(obj.has(o, hello, world))

p.world = true

sp.r = o - p

assert(obj.has(sp.r, hello) and not obj.has(sp.r, world))

assert(sp.r.hello == 42 and sp.r.world == nil)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o[hello] = 42

p[world] = 91

sp.r = o | p

assert(obj.has(sp.r, hello, world))

assert(sp.r.hello == 42 and sp.r.world == 91)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o.hello = 42

o.world = 91

assert(obj.has(o, hello, world))

p.world = true

sp.r = o & p

assert(not obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == nil and sp.r.world == true)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o.hello = 100

o.world = 200

assert(obj.has(o, hello, world))

p.hello = 42

p.world = 91

assert(obj.has(p, hello, world))

sp.r = o + p

assert(obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == 42 and sp.r.world == 91)

sp.r = p + o

assert(obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == 100 and sp.r.world == 200)

sp.r = o & p

assert(obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == 42 and sp.r.world == 91)

sp.r = p & o

assert(obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == 100 and sp.r.world == 200)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// __str, __call and __type
// when the prototype is a different object

sp.__str = "bear"

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(format("%v", o) == "bear")

assert(format("%v", p) == "bear")

assert(format("%v", sp) == `bear`)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(format("%v", o) == "{}")

assert(format("%v", p) == "{}")

p.hello = 42

o.world = 91

assert(format("%v", o) == "{world: 91}")

assert(format("%v", p) == "{hello: 42}")

assert(format("%v", sp) == "{}")

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(p) and obj.getmeta(p) == sp)

assert(type(o) == "object" and type(p) == "object" and type(sp) == "object")

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

sp.__type = 42

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(p) and obj.getmeta(p) == sp)

assert(type(o) == "42" and type(p) == "42" and type(sp) == "42")

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

assert(not obj.hasmeta(o))

assert(not obj.hasmeta(p))

assert(not obj.hasmeta(sp))

p.__call = 42

obj.setmeta(o, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.isCallable(o) and obj.isCallable(p))

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// When it has not prototype

o.__type = hello

o.__str = hello

o.__call = hello

assert(obj.hasmeta(o) == false)

assert(obj.isCallable(o))

assert(type(o) == hello)

assert(o() == hello)

assert(format("%v", o) == hello)

o[hello] = 42

o.__call = fun self => self.hello

assert(o() == o.hello)

o.hello = 91

assert(o() == o.hello)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// prototype chain with metamethods
// __str, __type, __call

sp.__str = hello

sp.__type = world

sp.__call = fun => 42*2

sp.hello = 42

sp.world = 91

p.alpha = 55

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(obj.isEmpty(o))

assert(o.alpha == 55 and o.hello == 42 and o.world == 91)

assert(format("%v", sp) == hello)

assert(format("%v", p) == hello)

assert(format("%v", o) == hello)

assert(type(o) == world and type(p) == world and type(sp) == world)

assert(not obj.isCallable(o) and obj.isCallable(p) and obj.isCallable(sp))

assert(p() == 42*2)

assert(sp() == 42*2)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// operator overloading
// __add, __sub, __mul, __div, __rem



// __eq, __neq, __le, __lt, __ge, __gt



// __bor, __bxor, __bshl, __bshr, __band



// __umin, __uplus, __unot, __ubnot



