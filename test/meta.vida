var obj = load("std/object")


// The library exists and has all the expected functionality
assert(
    obj and
    obj.set and
    obj.keys and
    obj.getset and
    obj.inject and
    obj.extends and
    obj.conforms and
    obj.implements and
    obj.del and
    obj.setmeta and
    obj.getmeta and
    obj.extract and
    obj.override and
    obj.has and
    obj.values and
    obj.get and
    obj.isEmpty and
    obj.clear and
    obj.hasmeta and
    obj.delmeta and
    obj.isObject and
    obj.isCallable
)



// set, get, has and del with one value

var k = nil

var v = nil

var t = {}

var o = {}

var p = {}

var sp = {}

assert(obj.isObject(t))

assert(obj.isObject(o))

assert(obj.isObject(p))

assert(obj.isObject(sp))

assert(obj.isCallable(t) == false)

assert(obj.isCallable(o) == false)

assert(obj.isCallable(p) == false)

assert(obj.isCallable(sp) == false)

var hello = "hello"

var world = "world"

assert(o and p and sp and t)

assert(o == o and p == p and sp == sp and t == t)

assert(o != t and o != p and o != sp and p != sp and t != p)

assert(obj.isEmpty(o) and obj.isEmpty(t) and obj.isEmpty(p) and obj.isEmpty(sp))

t[o] = true

t[p] = true

t[sp] = true

obj.set(o, "hello", 42)

obj.set(o, hello, 42)

assert(not obj.isEmpty(o) and len(o) == 1)

obj.set(o, "world", obj.get(o, "hello") * 2)

obj.set(o, world, obj.get(o, hello) * 2)

assert(not obj.isEmpty(o) and len(o) == 2)

assert(obj.get(o, "hello") == 42)

assert(obj.get(o, hello) == 42)

assert(obj.get(o, "world") == 42*2)

assert(obj.get(o, world) == 42*2)

assert(obj.has(o, hello) and obj.has(o, world))

assert(obj.has(o, "hello") and obj.has(o, "world"))

obj.del(o, hello)

assert(not obj.isEmpty(o) and len(o) == 1)

obj.del(o, world)

assert(obj.isEmpty(o))



// set, get, has, clear and del with more than one value

obj.set(o, hello, 42, world, 42*2)

assert(not obj.isEmpty(o) and len(o) == 2)

assert(obj.get(o, hello) == 42 and obj.get(o, world) == 42*2)

assert(obj.has(o, hello, world))

assert(not obj.has(o, hello, world, "alpha"))

obj.del(o, hello, world)

assert(obj.isEmpty(o))

obj.set(o, hello, 42, world, 42*2)

assert(not obj.isEmpty(o) and len(o) == 2)

obj.clear(o)

assert(not obj.has(o, hello, world, "alpha"))

assert(obj.isEmpty(o))

assert(t[o] and t[p] and t[sp])



// keys, values and getset

obj.set(o, hello, 42, world, 42*2)

k = obj.keys(o)

v = obj.values(o)

assert(len(k) == 2 and type(k) == "array" and len(v) == 2 and type(v) == "array")

assert(hello in k and world in k)

assert(42 in v and 42*2 in v)

obj.clear(o)

assert(t[o] and t[p] and t[sp])

assert(obj.isEmpty(o))

obj.getset(o, hello, 42)

obj.getset(o, world, 42*2)

assert(not obj.isEmpty(o) and len(o) == 2)

assert(obj.getset(o, hello, 100) == 42)

assert(obj.getset(o, world, 200) == 42*2)

k = obj.keys(o)

v = obj.values(o)

assert(len(k) == 2 and type(k) == "array" and len(v) == 2 and type(v) == "array")

assert(hello in k and world in k)

assert(42 in v and 42*2 in v)

obj.clear(o)

assert(t[o] and t[p] and t[sp])

assert(obj.isEmpty(o))



// metaobject
// object as metaobject of itself

o.__get = 42

o.__set = nil

assert(obj.hasmeta(o) == false)

obj.setmeta(o, o)

assert(obj.hasmeta(o) == true)

assert(o.hello and o[hello] and o.hello == 42 and o[hello] == 42)

assert(not obj.isEmpty(o) and len(o) == 2)

o[53] = 53

assert(o[53] == 42)

assert(not obj.isEmpty(o) and len(o) == 2)

assert(o == obj.getmeta(o) and t[obj.getmeta(o)])

obj.clear(o)

assert(t[o] and t[p] and t[sp])

assert(obj.isEmpty(o))

assert(obj.hasmeta(o) == false)

obj.setmeta(o, o)

assert(obj.hasmeta(o) == true)

assert(not o.hello and not o[hello] and o.hello == nil and o[hello] == nil)

assert(obj.isEmpty(o))

obj.delmeta(o)

assert(obj.hasmeta(o) == false)

assert(obj.isEmpty(o))

obj.clear(o)

assert(t[o] and t[p] and t[sp])

p.__get = 42

p.__set = nil

o = obj.setmeta(o, p)

assert(o.hello and o[hello] and o.hello == 42 and o[hello] == 42)

assert(obj.isEmpty(o) and len(o) == 0)

o[53] = 53

assert(o[53] == 42)

assert(obj.isEmpty(o) and len(o) == 0)

obj.clear(o)

assert(t[o] and t[p] and t[sp])

o.hello = 42

assert(not obj.isEmpty(o) and len(o) == 1)

obj.del(o, hello)

assert(obj.isEmpty(o) and len(o) == 0)

assert(o.hello == o[hello] and o.hello == nil)

obj.del(o, "__del")

assert(obj.isEmpty(o) and len(o) == 0)

assert(o.hello == o[hello] and o.hello == nil)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// object as metaobject of other objects
// metaobject equivalent of prototype chain

p.hello = 42

p.world = 91

assert(p.hello == 42 and p.world == 91)

assert(obj.hasmeta(o) == false)

obj.setmeta(o, p)

assert(obj.hasmeta(o) == true)

assert(obj.isEmpty(o))

assert(o.hello == 42 and o.world == 91)

o.getHello = fun self => self.hello

assert(o:getHello() == 42)

obj.clear(o)

assert(t[o] and t[p] and t[sp])

assert(obj.isEmpty(o))

assert(obj.hasmeta(o) == false)

obj.setmeta(o, p)

assert(obj.hasmeta(o) == true)

assert(obj.isEmpty(o))

p.getHello = fun self => self.hello

p.getWorld = fun self => self.world

assert(o:getHello() == 42)

assert(o:getWorld() == 91)

obj.delmeta(o)

assert(obj.hasmeta(o) == false)

obj.clear(p)



// metaobject get, set, has, del

p.__getmeta = false

p.__setmeta = false

obj.setmeta(o, p)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == false)

assert(obj.hasmeta(o))

obj.delmeta(o)

assert(obj.hasmeta(o))

obj.clear(p)

p.hello = 42

assert(o.hello == 42)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == p)

p.__setmeta = false

obj.clear(o)

obj.setmeta(o, p)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == p)

obj.setmeta(o, t)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == p)

obj.clear(p)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == p)

obj.setmeta(o, t)

assert(obj.hasmeta(o))

assert(obj.getmeta(o) == t)

obj.delmeta(o)

assert(obj.hasmeta(o) == false)

obj.clear(o)

sp.hello = fun => 42

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(o.hello() == 42)

assert(o.hello and type(o.hello) == "function")

assert(o.world == nil)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o[hello] = 42

p[world] = 91

sp.r = o + p

assert(obj.has(sp.r, hello, world))

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o.hello = 42

o.world = 91

assert(obj.has(o, hello, world))

p.world = true

sp.r = o - p

assert(obj.has(sp.r, hello) and not obj.has(sp.r, world))

assert(sp.r.hello == 42 and sp.r.world == nil)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o[hello] = 42

p[world] = 91

sp.r = o | p

assert(obj.has(sp.r, hello, world))

assert(sp.r.hello == 42 and sp.r.world == 91)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o.hello = 42

o.world = 91

assert(obj.has(o, hello, world))

p.world = true

sp.r = o & p

assert(not obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == nil and sp.r.world == true)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

o.hello = 100

o.world = 200

assert(obj.has(o, hello, world))

p.hello = 42

p.world = 91

assert(obj.has(p, hello, world))

sp.r = o + p

assert(obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == 42 and sp.r.world == 91)

sp.r = p + o

assert(obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == 100 and sp.r.world == 200)

sp.r = o & p

assert(obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == 42 and sp.r.world == 91)

sp.r = p & o

assert(obj.has(sp.r, hello) and obj.has(sp.r, world))

assert(sp.r.hello == 100 and sp.r.world == 200)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// __str, __call and __type
// when the metaobject is a different object

sp.__str = "bear"

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(format("%v", o) == "{}")

assert(format("%v", p) == "bear")

assert(format("%v", sp) == `{__str: bear}`)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(format("%v", o) == "{}")

assert(format("%v", p) == "{}")

p.hello = 42

o.world = 91

assert(format("%v", o) == "{world: 91}")

assert(format("%v", p) == "{hello: 42}")

assert(format("%v", sp) == "{}")

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(p) and obj.getmeta(p) == sp)

assert(type(o) == "object" and type(p) == "object" and type(sp) == "object")

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

sp.__type = 42

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(p) and obj.getmeta(p) == sp)

assert(type(o) == "object" and type(p) == "42" and type(sp) == "object")

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

assert(not obj.hasmeta(o))

assert(not obj.hasmeta(p))

assert(not obj.hasmeta(sp))

p.__call = 42

obj.setmeta(o, p)

obj.setmeta(p, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(p) and obj.getmeta(p) == p)

assert(obj.isCallable(o) and obj.isCallable(p))

assert(p() == o() and p() == p.__call)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// When it has not metaobject

o.__type = hello

o.__str = hello

o.__call = hello

assert(obj.hasmeta(o) == false)

assert(obj.isCallable(o) == false)

assert(type(o) != hello)

assert(format("%v", o) != hello)

o = obj.setmeta(o, o)

assert(t[o] and t[p] and t[sp])

assert(obj.hasmeta(o) == true)

assert(obj.isCallable(o) == true)

assert(type(o) == hello)

assert(o() == hello)

assert(format("%v", o) == hello)

o[hello] = 42

o.__call = fun self => self.hello

assert(o() == o.hello)

o.hello = 91

assert(o() == o.hello)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// metaobject chain with metamethods
// __str, __type, __call

sp.__str = hello

sp.__type = world

sp.__call = fun => 42*2

sp.hello = 42

sp.world = 91

p.alpha = 55

obj.setmeta(p, sp)

obj.setmeta(o, p)

assert(obj.isEmpty(o))

assert(o.alpha == 55 and o.hello == 42 and o.world == 91)

assert(format("%v", sp) != hello)

assert(format("%v", p) == hello)

assert(format("%v", o) != hello)

assert(type(o) == "object" and type(p) == world and type(sp) == "object")

assert(not obj.isCallable(o) and obj.isCallable(p) and not obj.isCallable(sp))

assert(p() == 42*2)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// __setmeta, not __setmeta and __getmeta

p.hello = 42

o.world = 91

assert(obj.hasmeta(o) == false)

obj.setmeta(o, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(o.hello == p.hello and o.world == 91)

obj.clear(o, p)

p.hello = 1000

p.world = 2000

assert(obj.hasmeta(o) == false)

o = obj.setmeta(o, p)

assert(t[o] and t[p] and t[sp])

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(o.hello == p.hello and o.world == p.world)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

p.__setmeta = nil

p.data = 42

obj.setmeta(o, p)

assert(o.data == p.data)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

sp.r = obj.setmeta(o, sp)

assert(t[o] and t[p] and t[sp])

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(o.data == p.data)

assert(sp.r == p.__setmeta)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// not __getmeta

p.hello = 1000

p.world = 2000

p.__getmeta = hello

assert(obj.hasmeta(o) == false and obj.getmeta(o) == nil)

o = obj.setmeta(o, p)

assert(t[o] and t[p] and t[sp])

assert(obj.hasmeta(o) and obj.getmeta(o) == p.__getmeta)

assert(o.hello == p.hello and o.world == p.world)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// not __getmeta and not __setmeta

p.hello = 1000

p.world = 2000

p.__getmeta = hello

p.__setmeta = world

assert(obj.hasmeta(o) == false and obj.getmeta(o) == nil)

o = obj.setmeta(o, p)

assert(t[o] and t[p] and t[sp])

assert(obj.hasmeta(o) and obj.getmeta(o) == p.__getmeta)

assert(o.hello == p.hello and o.world == p.world)

sp.r = obj.setmeta(o, sp)

assert(obj.hasmeta(o) and obj.getmeta(o) == p.__getmeta)

assert(obj.hasmeta(o) and sp.r == p.__setmeta)

assert(o.hello == p.hello and o.world == p.world)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// delmeta with and without guard

p.hello = 1000

p.world = 2000

o.hello = 42

o.world = 91

assert(obj.hasmeta(o) == false and obj.getmeta(o) == nil)

o = obj.setmeta(o, p)

p = obj.setmeta(p, sp)

assert(t[o] and t[p] and t[sp])

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(p) and obj.getmeta(p) == sp)

assert(o.hello and p.hello and o.world and p.world)

obj.delmeta(o, p. sp)

assert(not obj.hasmeta(o) and not obj.hasmeta(o) and not obj.hasmeta(sp))

assert(p.hello == 1000 and p.world == 2000 and o.hello == 42 and o.world == 91)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

p.hello = 1000

p.world = 2000

p.__setmeta = hello

assert(obj.hasmeta(o) == false and obj.getmeta(o) == nil)

o = obj.setmeta(o, p)

assert(t[o] and t[p] and t[sp])

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

obj.delmeta(o, p. sp)

assert(o.hello == p.hello and o.world == p.world)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])



// operator overloading
// __add, __sub, __mul, __div, __rem

p.__add = fun self, other {
    ret 42
}

p.__sub = fun self, other {
    ret 43
}

p.__mul = fun self, other {
    ret 44
}

p.__div = fun self, other {
    ret 45
}

p.__rem = fun self, other {
    ret 46
}

o = obj.setmeta(o, p)

sp = obj.setmeta(sp, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(sp) and obj.getmeta(sp) == p)

assert(t[o] and t[p] and t[sp])

assert(o + sp == sp + o and o + sp == 42)

assert(o - sp == sp - o and o - sp == 43)

assert(o * sp == sp * o and o * sp == 44)

assert(o / sp == sp / o and o / sp == 45)

assert(o % sp == sp % o and o % sp == 46)

obj.clear(o, p, sp)

assert(not obj.hasmeta(o))

assert(not obj.hasmeta(sp))

assert(t[o] and t[p] and t[sp])



// __eq, __le, __lt, __ge, __gt

p.__eq = fun self, other {
    ret 47
}

p.__le = fun self, other {
    ret 49
}

p.__lt = fun self, other {
    ret 50
}

p.__ge = fun self, other {
    ret 51
}

p.__gt = fun self, other {
    ret 52
}

o = obj.setmeta(o, p)

sp = obj.setmeta(sp, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(sp) and obj.getmeta(sp) == p)

assert(t[o] and t[p] and t[sp])

assert((o == sp) == (sp == o) and (o == sp) == true)

assert((o != sp) == (sp != o) and (o != sp) == not(o == sp))

assert((o <= sp) == (sp <= o) and (o <= sp) == 49)

assert((o < sp) == (sp < o) and (o < sp) == 50)

assert((o >= sp) == (sp >= o) and (o >= sp) == 51)

assert((o > sp) == (sp > o) and (o > sp) == 52)

obj.clear(o, p, sp)

assert(not obj.hasmeta(o))

assert(not obj.hasmeta(sp))

assert(t[o] and t[p] and t[sp])



// __umin, __uplus

p.__umin = fun self {
    ret 100
}

p.__uplus = fun self {
    ret 200
}

o = obj.setmeta(o, p)

sp = obj.setmeta(sp, p)

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(sp) and obj.getmeta(sp) == p)

assert(t[o] and t[p] and t[sp])

assert(-o == 100 and +o == 200)

assert(-sp == 100 and +sp == 200)

obj.clear(o, p, sp)

assert(not obj.hasmeta(o))

assert(not obj.hasmeta(sp))

assert(t[o] and t[p] and t[sp])



// __add, __sub, __mul, __div, __rem checking both arguments

p.__add = fun self, other {
    ret self.hello + other.hello
}

p.__sub = fun self, other {
    ret self.hello - other.hello
}

p.__mul = fun self, other {
    ret self.hello * other.hello
}

p.__div = fun self, other {
    ret self.hello / other.hello
}

p.__rem = fun self, other {
    ret self.hello % other.hello
}

o = obj.setmeta(o, p)

sp = obj.setmeta(sp, p)

o.hello = 100

sp.hello = 100

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(sp) and obj.getmeta(sp) == p)

assert(t[o] and t[p] and t[sp])

assert(o + sp == sp + o and o + sp == (o.hello + sp.hello) and sp + o == 200)

assert(o - sp == sp - o and o - sp == (o.hello - sp.hello) and sp - o == 0)

assert(o * sp == sp * o and o * sp == (o.hello * sp.hello) and sp * o == 100*100)

assert(o / sp == sp / o and o / sp == (o.hello / sp.hello) and sp / o == 100/100)

assert(o % sp == sp % o and o % sp == (o.hello % sp.hello) and sp % o == 100%100)

obj.clear(o, p, sp)

assert(not obj.hasmeta(o))

assert(not obj.hasmeta(sp))

assert(t[o] and t[p] and t[sp])



// __eq, __le, __lt, __ge, __gt checking both arguments

p.__eq = fun self, other {
    ret self.hello == other.hello
}

p.__le = fun self, other {
    ret self.hello <= other.hello
}

p.__lt = fun self, other {
    ret self.hello < other.hello
}

p.__ge = fun self, other {
    ret self.hello >= other.hello
}

p.__gt = fun self, other {
    ret self.hello > other.hello
}

o = obj.setmeta(o, p)

sp = obj.setmeta(sp, p)

o.hello = 100

sp.hello = 100

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(sp) and obj.getmeta(sp) == p)

assert(t[o] and t[p] and t[sp])

assert((o == sp) == (sp == o) and (o == sp) == (o.hello == sp.hello) and (sp == o) == (100==100))

assert((o != sp) == (sp != o) and (o != sp) == (o.hello != sp.hello) and (sp != o) == (100!=100))

assert((o <= sp) == (sp <= o) and (o <= sp) == (o.hello <= sp.hello) and (sp <= o) == (100<=100))

assert((o < sp) == (sp < o) and (o < sp) == (o.hello < sp.hello) and (sp < o) == (100<100))

assert((o >= sp) == (sp >= o) and (o >= sp) == (o.hello >= sp.hello) and (sp >= o) == (100>=100))

assert((o > sp) == (sp > o) and (o > sp) == (o.hello > sp.hello) and (sp > o) == (100>100))

obj.clear(o, p, sp)

assert(not obj.hasmeta(o))

assert(not obj.hasmeta(sp))

assert(t[o] and t[p] and t[sp])



// __eq, __le, __lt, __ge, __gt checking both arguments

p.__eq = fun self, other {
    ret self.hello == other.hello
}

p.__le = fun self, other {
    ret self.hello <= other.hello
}

p.__lt = fun self, other {
    ret self.hello < other.hello
}

p.__ge = fun self, other {
    ret self.hello >= other.hello
}

p.__gt = fun self, other {
    ret self.hello > other.hello
}

o = obj.setmeta(o, p)

sp = obj.setmeta(sp, p)

o.hello = 100

sp.hello = 200

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(sp) and obj.getmeta(sp) == p)

assert(t[o] and t[p] and t[sp])

assert((o == sp) == (sp == o) and (o == sp) == (o.hello == sp.hello) and (sp == o) == (100==200))

assert((o != sp) == (sp != o) and (o != sp) == (o.hello != sp.hello) and (sp != o) == (100!=200))

assert((o <= sp) == (o.hello <= sp.hello) and (o <= sp) == (100<=200))

assert((o < sp) == (o.hello < sp.hello) and (o < sp) == (100<200))

assert((o >= sp) == (o.hello >= sp.hello) and (o >= sp) == (100>=200))

assert((o > sp) == (o.hello > sp.hello) and (o > sp) == (100>200))

assert((sp <= o) == (sp.hello <= o.hello) and (sp <= o) == (200<=100))

assert((sp < o) == (sp.hello < o.hello) and (sp < o) == (200<100))

assert((sp >= o) == (sp.hello >= o.hello) and (sp >= o) == (200>=100))

assert((sp > o) == (sp.hello > o.hello) and (sp > o) == (200>100))

obj.clear(o, p, sp)

assert(not obj.hasmeta(o))

assert(not obj.hasmeta(sp))

assert(t[o] and t[p] and t[sp])



// __umin, __uplus checking values

p.__umin = fun self {
    ret -self.hello
}

p.__uplus = fun self {
    ret +self.hello
}

o = obj.setmeta(o, p)

sp = obj.setmeta(sp, p)

o.hello = 42

sp.hello = -91

assert(obj.hasmeta(o) and obj.getmeta(o) == p)

assert(obj.hasmeta(sp) and obj.getmeta(sp) == p)

assert(t[o] and t[p] and t[sp])

assert(-o == -42 and +o == 42)

assert(-sp == 91 and +sp == -91)

obj.clear(o, p, sp)

assert(not obj.hasmeta(o))

assert(not obj.hasmeta(sp))

assert(t[o] and t[p] and t[sp])



// keys and values

p.hello = 42

p.world = 91

assert(hello in obj.keys(p) and world in obj.keys(p))

assert(42 in obj.values(p) and 91 in obj.values(p))



// isEmpty, isObject and isCallable

assert(not obj.isEmpty(p))

assert(obj.isObject(p) and obj.isObject(o) and obj.isObject(sp))

assert(not obj.isObject(hello) and not obj.isObject(world) and not obj.isObject(42))

assert(not obj.isCallable(p) and not obj.isCallable(o) and not obj.isCallable(sp))



// getset

assert(obj.getset(p, hello) == p.hello)

assert(obj.getset(p, world) == p.world)

assert(obj.getset(p, "sheep", "cow") == p)

assert(obj.getset(p, "sheep") == "cow")



// clear

obj.clear(o, p, sp)

assert(t[o] and t[p] and t[sp])

assert(obj.isEmpty(o) and obj.isEmpty(p) and obj.isEmpty(sp))

assert(not obj.hasmeta(o) and not obj.hasmeta(p) and not obj.hasmeta(sp))

