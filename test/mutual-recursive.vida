/*
* Mutual Recursive Functions Calls
*/

let cons = nil
let prod = nil
let totalCalls = 0
let N = 23

prod = fun x {
    totalCalls = totalCalls + 1
    for i in 0, x {
        cons(i)
    }
}

cons = fun x {
    totalCalls = totalCalls + 1
    for i in 0, x {
        prod(i)
    }
}

prod(N)
assert(totalCalls==8_388_608)
