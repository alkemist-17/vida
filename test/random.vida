var rand = load("std/rand")

var N = 20

for in N {print(rand.N())}
for in N {print(rand.I())}
for in N {print(rand.U32())}
for in N {print(rand.F())}
for in N {print(rand.norm())}
for in N {print(rand.exp())}
for in N {print(rand.perm(10))}
for in N {print(rand.zipf())}
for in N {print(rand.pcg())}
for in N {print(rand.CC8())}
for in N {print(rand.bytes(16))}
for in N {print(rand.text())}
for in N {print(rand.nanoid())}
for in N {assert(len(rand.nanoid()) == rand.nanoidDefaultSize)}

var size = 31
for in N {print(rand.nanoid(size))}
for in N {assert(len(rand.nanoid(size)) == size)}

size = 119
var nanoid = rand.nanoidWithCustomAlpha("abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0987654321", size)

for in N {print(nanoid())}
for in N {assert(len(nanoid()) == size)}
