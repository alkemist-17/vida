var re = load("std/re")

var pattern = `^[a-z]+\[[0-9]+\]$`

var input = [
	"adam[23]",
	"eve[7]",
	"job[48]",
	"snakey[120]"
]


for _, v in input {
    assert(re.match(pattern, v))
}


input = [
    "345hjel",
    "Algo[2]",
    "Go[42]"
]

for _, v in input {
    assert(not re.match(pattern, v))
}


pattern = `(gopher){2}`

input = [
	"gophergopher",
	"gophergophergopher",
	"gophergophergophergopher"
]

for _, v in input {
    assert(re.match(pattern, v))
}


input = [
	"gopher",
	"gophergophe",
	"gophergophegophegophe"
]


for _, v in input {
    assert(not re.match(pattern, v))
}


pattern = `a(x*)b`
var src = "-ab-axxb-"

var repl = ["T", "$1", "$1W", "${1}W"]

assert(re.replaceAll(pattern, src, "T") == "-T-T-")
assert(re.replaceAll(pattern, src, "$1") == "--xx-")
assert(re.replaceAll(pattern, src, "$1W") == "---")
assert(re.replaceAll(pattern, src, "${1}W") == "-W-xxW-")


pattern = `[0-9]+`

assert(re.replaceAll(pattern, `hello837987342`, ``) == "hello")
assert(re.replaceAll(pattern, `5234523452345hel345345lo837987342`, ``) == "hello")
assert(re.replaceAll(pattern, `hello`, ``) == "hello")
assert(re.replaceAll(pattern, `345345345h345345345e345345345l345345345l345345345o837987342`, ``) == "hello")

pattern = `ab?`

var R = re.findFirstIndex(pattern, `tablet`)

assert(R[0] == 1 and R[1] == 3)
assert(`tablet`[R[0]..R[1]] == `ab`)
assert(re.findFirstIndex(pattern, `foo`) == nil)

pattern = `hello`
R = re.findFirstIndex(pattern, `hello world`)
assert(R[0] == 0 and R[1] == 5)

pattern = `o`
assert(re.replaceAll(pattern, `hello world`, "a") == "hella warld")

pattern = `1.5`

input = `
	invoice 1.5
	invoice 1.5
	invoice 1.5
`

R = re.replaceAll(pattern, input, "0.5")

pattern = `0.5`

R = re.findAllStrings(pattern, R, -1)

assert(len(R) == 3)


pattern = `hello.`

input = `hello.world!`

R = re.escape(pattern)

assert(R == `hello\.`)

assert(re.match(R, input))

assert(re.findString(R, input) == pattern)


