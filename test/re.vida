var re = load("std/re")

var pattern = `^[a-z]+\[[0-9]+\]$`

var input = [
	"adam[23]",
	"eve[7]",
	"job[48]",
	"snakey[120]"
]


for _, v in input {
    assert(re.match(pattern, v))
}


input = [
    "345hjel",
    "Algo[2]",
    "Go[42]"
]

for _, v in input {
    assert(not re.match(pattern, v))
}


pattern = `(gopher){2}`

input = [
	"gophergopher",
	"gophergophergopher",
	"gophergophergophergopher"
]

for _, v in input {
    assert(re.match(pattern, v))
}


input = [
	"gopher",
	"gophergophe",
	"gophergophegophegophe"
]


for _, v in input {
    assert(not re.match(pattern, v))
}


pattern = `a(x*)b`
var src = "-ab-axxb-"

var repl = ["T", "$1", "$1W", "${1}W"]

assert(re.replaceAll(pattern, src, repl[0]) == "-T-T-")
assert(re.replaceAll(pattern, src, repl[1]) == "--xx-")
assert(re.replaceAll(pattern, src, repl[2]) == "---")
assert(re.replaceAll(pattern, src, repl[3]) == "-W-xxW-")

assert(re.replaceAllLiteral(pattern, src, repl[0]) == "-T-T-")
assert(re.replaceAllLiteral(pattern, src, repl[1]) == "-$1-$1-")
assert(re.replaceAllLiteral(pattern, src, repl[2]) == "-$1W-$1W-")
assert(re.replaceAllLiteral(pattern, src, repl[3]) == "-${1}W-${1}W-")


pattern = `[0-9]+`

assert(re.replaceAll(pattern, `hello837987342`, ``) == "hello")
assert(re.replaceAll(pattern, `5234523452345hel345345lo837987342`, ``) == "hello")
assert(re.replaceAll(pattern, `hello`, ``) == "hello")
assert(re.replaceAll(pattern, `345345345h345345345e345345345l345345345l345345345o837987342`, ``) == "hello")

pattern = `ab?`

var R = re.findFirstIndex(pattern, `tablet`)

assert(R[0] == 1 and R[1] == 3)
assert(`tablet`[R[0]..R[1]] == `ab`)
assert(re.findFirstIndex(pattern, `foo`) == nil)

pattern = `hello`
R = re.findFirstIndex(pattern, `hello world`)
assert(R[0] == 0 and R[1] == 5)

pattern = `o`
assert(re.replaceAll(pattern, `hello world`, "a") == "hella warld")

pattern = `1.5`

input = `
	invoice 1.5
	invoice 1.5
	invoice 1.5
`

R = re.replaceAll(pattern, input, "0.5")

pattern = `0.5`

R = re.findAll(pattern, R, -1)

assert(len(R) == 3)


pattern = `hello.`

input = `hello.world!`

R = re.escape(pattern)

assert(R == `hello\.`)

assert(re.match(R, input))

assert(re.find(R, input) == pattern)


pattern = `ox`
input = "Fox box roxx cox brox"
R = re.findAllIndex(pattern, input, -1)


for _, pair in R {
	assert(input[pair[0]..pair[1]] == pattern)
}


pattern = `\d+`

input = "Look43453452at534543534534524the45554500542numbers7593847983745"

R = re.split(pattern, input, -1)

assert(R[0] == "Look")
assert(R[1] == "at")
assert(R[2] == "the")
assert(R[3] == "numbers")


pattern = `\-+`

input = "Look----at-the-----numbers------"

R = re.split(pattern, input, -1)

assert(R[0] == "Look")
assert(R[1] == "at")
assert(R[2] == "the")
assert(R[3] == "numbers")


pattern = `(\+|\-)?\d+\.\d+`

input = [
	"12.124",
	"+1.35",
	"-2.34",
	"+2."
]

R = re.findSubMatch(pattern, input[0])
assert(R[0] == "12.124" and R[1] == "")

R = re.findSubMatch(pattern, input[1])
assert(R[0] == "+1.35" and R[1] == "+")

R = re.findSubMatch(pattern, input[2])
assert(R[0] == "-2.34" and R[1] == "-")

assert(re.findSubMatch(pattern, input[3]) == nil)
