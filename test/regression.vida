data = {}
assert(data.len() == 0 and data.hello == nil)

data = { hello beautiful world }
assert(data.len() == 3 and not data.hello and not data.beautiful and not data.world)

data = { hello, beautiful, world, }
assert(data.len() == 3 and not data.hello and not data.beautiful and not data.world)

data = { hello, beautiful world }
assert(data.len() == 3 and not data.hello and not data.beautiful and not data.world)

data = { hello beautiful, world }
assert(data.len() == 3 and not data.hello and not data.beautiful and not data.world)

data = { hello beautiful world, }
assert(data.len() == 3 and not data.hello and not data.beautiful and not data.world)

data = { hello, beautiful, world }
assert(data.len() == 3 and not data.hello and not data.beautiful and not data.world)

data = { hello beautiful, world, }
assert(data.len() == 3 and not data.hello and not data.beautiful and not data.world)

data = { hello, beautiful world, }
assert(data.len() == 3 and not data.hello and not data.beautiful and not data.world)

data = { hello, beautiful, world }
assert(data.len() == 3 and not data.hello and not data.beautiful and not data.world)

i = 90

data = {
    hello = i
    beautiful = i
    world = i
}
assert(data.len() == 3 and data.hello == i and data.beautiful == i and data.world == i)
assert(data.len() == 3 and -data.hello == -i and -data.beautiful == -i and -data.world == -i)

data = {
    hello = i
    beautiful
    world
}
assert(data.len() == 3 and data.hello == i and data.beautiful == nil and data.world == nil)
assert(data.len() == 3 and -data.hello == -i and not data.beautiful and not data.world)

data = {
    hello
    beautiful = i
    world
}
assert(data.len() == 3 and data.hello == nil and data.beautiful == i and data.world == nil)
assert(data.len() == 3 and not data.hello and -data.beautiful == -i and not data.world)

data = {
    hello
    beautiful
    world = i
}
assert(data.len() == 3 and data.hello == nil and data.beautiful == nil and data.world == i)
assert(data.len() == 3 and not data.hello and not data.beautiful and -data.world == -i)


data = {
    hello
    beautiful = i
    world = i
}
assert(data.len() == 3 and data.hello == nil and data.beautiful == i and data.world == i)
assert(data.len() == 3 and not data.hello and -data.beautiful == -i and -data.world == -i)


data = {
    hello = i
    beautiful = i
    world
}
assert(data.len() == 3 and data.hello == i and data.beautiful == i and data.world == nil)
assert(data.len() == 3 and -data.hello == -i and -data.beautiful == -i and not data.world)

data = {
    hello = i
    beautiful
    world = i
}
assert(data.len() == 3 and data.hello == i and data.beautiful == nil and data.world == i)
assert(data.len() == 3 and -data.hello == -i and not data.beautiful and -data.world == -i)


