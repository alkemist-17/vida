data = [1, 2, 3,]
assert(data.len() == 3 and data[0] == 1 and data[1] == 2 and data[2] == 3)

data = [1, 2, 3,]
assert(data.len() == 3 and data[0] == 1 and data[1] == 2 and data[2] == 3)

data = [1, 2, 3]
assert(data.len() == 3 and data[0] == 1 and data[1] == 2 and data[2] == 3)

data = [1, 2, 3]
assert(data.len() == 3 and data[0] == 1 and data[1] == 2 and data[2] == 3)

data = [1, 2, 3,]
assert(data.len() == 3 and data[0] == 1 and data[1] == 2 and data[2] == 3)

data = [1, 2, 3]
assert(data.len() == 3 and data[0] == 1 and data[1] == 2 and data[2] == 3)

data = [1, 2, 3,]
assert(data.len() == 3 and data[0] == 1 and data[1] == 2 and data[2] == 3)

data = [1, 2, 3,]
assert(data.len() == 3 and data[0] == 1 and data[1] == 2 and data[2] == 3)

data = [1, 2, 3]
