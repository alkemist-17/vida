
// First test with local variables on module level

var a = "hello"
var b = nil
var f = fun -> a + format("%v", b)

var result = f()
assert(result == "hellonil", "format should work as function alone and it should have + as rhs of addition op")

f = fun -> a + "%v".format(b)
result = f()
assert(result == "hellonil", "format should work as string method and it should have + as rhs of addition op")

f = fun -> format("%v", b) + a
result = f()
assert(result == "nilhello", "format should work as function alone and it should have + as lhs of addition op")

f = fun -> "%v".format(b) + a
result = f()
assert(result == "nilhello", "format should work as string method and it should have + as lhs of addition op")


// An arbitrary object can in principle be a vtable of itself
// although it is memory redundat in case of having fields
// because of innecessary duplication of data as we will see in this test.
var data = {
    id = 42
    name = "data"
    email = "data@data.data"
    getId = fun self -> self.id
    getName = fun self -> self.name
    getEmail = fun self -> self.email
}


data = data =< data
assert(data == data, "after an object vtable assignment the object should be the same")
assert(data == data, "an object can be the vtable of itself")
assert(data.id == 42 and data.name == "data" and data.email == "data@data.data", "selection operations on own fields should work well")

for in 1000 {
    var data = data.clone()
    assert(data.getId() == data.id, "method call on itself as its own vtable should retrieve its own fields")
    assert(data.getName() == data.name, "method call on itself as its own vtable should retrieve its own fields")
    assert(data.getEmail() == data.email, "method call on itself as its own vtable should retrieve its own fields")
    data.getId() // This is for method call as stmt
    data.getName()
    data.getEmail()
}

for in 1000 {
    var data = data.clone()
    assert(data::getId(data) == data.id, "static calls with explicit object receiver setting should get the same results as method calls")
    assert(data::getName(data) == data.name, "static calls with explicit object receiver setting should get the same results as method calls")
    assert(data::getEmail(data) == data.email, "static calls with explicit object receiver setting should get the same results as method calls")
    data::getId(data) // This is for static calls as stmts
    data::getName(data)
    data::getEmail(data)
}

var src = [1, 2, 3, 4, 5] // This values should be all different

data = [
    [
        [
            [
                [
                    src[0],
                    src[1],
                    src[2],
                    src[3],
                    src[4],
                ]
            ]
        ]
    ]
]

// To test combinations of locals and module level vars used as indexes in arrays
var i = 0
let j = [0, 1, 2, 3, 4, ]
assert(j and j.type() == [].type() and j.len() == 5, "an array can have a trailing comman after the last element")

assert(data[i][i][i][i][j[0]] == src[0], "combinations of locals and module level vars can be used as indexes in arrays")
assert(data[i][i][i][i][j[1]] == src[1], "combinations of locals and module level vars can be used as indexes in arrays")
assert(data[i][i][i][i][j[2]] == src[2], "combinations of locals and module level vars can be used as indexes in arrays")
assert(data[i][i][i][i][j[3]] == src[3], "combinations of locals and module level vars can be used as indexes in arrays")
assert(data[i][i][i][i][j[4]] == src[4], "combinations of locals and module level vars can be used as indexes in arrays")

assert(data[i][i][i][i][j[0]] != src[4], "combinations of locals and module level vars can be used as indexes in arrays")
assert(data[i][i][i][i][j[1]] != src[3], "combinations of locals and module level vars can be used as indexes in arrays")
assert(data[i][i][i][i][j[2]] != src[0], "combinations of locals and module level vars can be used as indexes in arrays")
assert(data[i][i][i][i][j[3]] != src[1], "combinations of locals and module level vars can be used as indexes in arrays")
assert(data[i][i][i][i][j[4]] != src[0], "combinations of locals and module level vars can be used as indexes in arrays")


data = [
    1, 1, 1,
    0, 0, 0,
    2, 2, 2,
]

assert(
    data[0] == 1 and data[1] == 1 and data[2] == 1 or
    data[3] == 1 and data[4] == 1 and data[5] == 1 or
    data[6] == 1 and data[7] == 1 and data[8] == 1 or
    data[0] == 1 and data[4] == 1 and data[8] == 1 or
    data[2] == 1 and data[4] == 1 and data[6] == 1 or
    data[0] == 1 and data[3] == 1 and data[6] == 1 or
    data[1] == 1 and data[4] == 1 and data[7] == 1 or
    data[2] == 1 and data[5] == 1 and data[8] == 1,
    "const numerics literals can be used as indexes in arrays"
)

assert(
    data[0] == 1 and data[1] == 1 and data[2] == 0 or
    data[3] == 0 and data[4] == 0 and data[5] == 0 or
    data[6] == 1 and data[7] == 1 and data[8] == 0 or
    data[0] == 1 and data[4] == 1 and data[8] == 0 or
    data[2] == 1 and data[4] == 1 and data[6] == 0 or
    data[0] == 1 and data[3] == 1 and data[6] == 0 or
    data[1] == 1 and data[4] == 1 and data[7] == 0 or
    data[2] == 1 and data[5] == 1 and data[8] == 0,
    "const numerics literals can be used as indexes in arrays"
)

assert(
    data[0] == 1 and data[1] == 1 and data[2] == 2 or
    data[3] == 1 and data[4] == 1 and data[5] == 2 or
    data[6] == 2 and data[7] == 2 and data[8] == 2 or
    data[0] == 1 and data[4] == 1 and data[8] == 2 or
    data[2] == 1 and data[4] == 1 and data[6] == 2 or
    data[0] == 1 and data[3] == 1 and data[6] == 2 or
    data[1] == 1 and data[4] == 1 and data[7] == 2 or
    data[2] == 1 and data[5] == 1 and data[8] == 2,
    "const numerics literals can be used as indexes in arrays"
)

var cmp = {
    hello = 0
    world = 1
    gamma = 2
}

assert(
    data[0] == cmp.hello and data[1] == cmp.hello and data[2] == cmp.hello or
    data[3] == cmp.hello and data[4] == cmp.hello and data[5] == cmp.hello or
    data[6] == cmp.hello and data[7] == cmp.hello and data[8] == cmp.hello
)

assert(
    data[0] == cmp.world and data[1] == cmp.world and data[2] == cmp.world or
    data[3] == cmp.world and data[4] == cmp.world and data[5] == cmp.world or
    data[6] == cmp.world and data[7] == cmp.world and data[8] == cmp.world
)

assert(
    data[0] == cmp.gamma and data[1] == cmp.gamma and data[2] == cmp.gamma or
    data[3] == cmp.gamma and data[4] == cmp.gamma and data[5] == cmp.gamma or
    data[6] == cmp.gamma and data[7] == cmp.gamma and data[8] == cmp.gamma
)


