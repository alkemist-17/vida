//
// Asynchronous Programming
// Skynet Concurrency Test
//

/*
* Creates an actor (goroutine, whatever), which spawns 10 new actors, each of them spawns 10 more actors, etc. 
* until one million actors are created on the final level. 
* Then, each of them returns back its ordinal number (from 0 to 999999), 
* which are summed on the previous level and sent back upstream, 
* until reaching the root actor. (The answer should be 499999500000).
*/

var co = load("std/co")

var suspend = co.suspend
var run = co.run
var new = co.new

let skynet = fun num, size {
	if size == 1 {
		ret suspend(num)
	}
	size = size / 10
	var acc = 0
	for i in 0, 10 {
		var r = run(new(skynet), num + i * size, size)
		acc = acc + r
	}
	ret suspend(acc)
}

var result = run(new(skynet), 0, 1_000_000)

assert(result == 499_999_500_000)

