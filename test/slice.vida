var bytes = load("std/bytes")

// ============================================================
// ARRAY SLICES
// ============================================================

var A = [1, 2, 3, 4, 5]

// --- vcv: full copy A[..]
var B = A[..]
assert(len(B) == 5)
assert(B[0] == A[0] and B[4] == A[4])

// --- vce: from start to index A[..e]
var B = A[..3]
assert(len(B) == 3)
assert(B[0] == A[0] and B[2] == A[2])

// vce: end index == 0 → empty
var B = A[..0]
assert(len(B) == 0)

// vce: end index beyond length → full copy
var B = A[..99]
assert(len(B) == 5 and B[0] == A[0] and B[4] == A[4])

// vce: negative end index wraps around
var B = A[..-1]
assert(len(B) == 4)
assert(B[0] == A[0] and B[3] == A[3])

// vce: negative end wraps to 0 or below → empty
var B = A[..-99]
assert(len(B) == 0)

// --- ecv: from index onwards A[s..]
var B = A[1..]
assert(len(B) == 4)
assert(B[0] == A[1] and B[3] == A[4])

// ecv: start index == length → empty
var B = A[5..]
assert(len(B) == 0)

// ecv: start index beyond length → empty
var B = A[99..]
assert(len(B) == 0)

// ecv: negative start wraps around
var B = A[-2..]
assert(len(B) == 2)
assert(B[0] == A[3] and B[1] == A[4])

// ecv: negative start wraps beyond 0 → full copy
var B = A[-99..]
assert(len(B) == 5 and B[0] == A[0])

// --- ece: range A[s..e]
var B = A[1..4]
assert(len(B) == 3)
assert(B[0] == A[1] and B[2] == A[3])

// ece: s == e → empty
var B = A[2..2]
assert(len(B) == 0)

// ece: s > e (inverted) → empty
var B = A[3..1]
assert(len(B) == 0)

// ece: both negative, valid range
var B = A[-4..-1]
assert(len(B) == 3)
assert(B[0] == A[1] and B[2] == A[3])

// ece: negative start, positive end
var B = A[-3..4]
assert(len(B) == 2)
assert(B[0] == A[2] and B[1] == A[3])

// ece: start beyond length, end beyond length → empty
var B = A[99..100]
assert(len(B) == 0)

// ece: start == 0, end == length → full copy
var B = A[0..5]
assert(len(B) == 5 and B[0] == A[0] and B[4] == A[4])

// Independence: mutating B does not affect A
var B = A[1..4]
B[0] = 99
assert(A[1] == 2)
assert(not(B[0] == A[1]))


// ============================================================
// STRING SLICES (ASCII)
// ============================================================

var S = "hello"

// vcv: full copy
var B = S[..]
assert(len(B) == 5 and B == "hello")

// vce
var B = S[..3]
assert(B == "hel")

// ecv
var B = S[2..]
assert(B == "llo")

// ece
var B = S[1..4]
assert(B == "ell")

// ecv: negative start
var B = S[-3..]
assert(B == "llo")

// vce: negative end
var B = S[..-2]
assert(B == "hel")

// ece: out-of-range end clamps to length
var B = S[1..99]
assert(B == "ello")

// ece: s == e → empty string
var B = S[2..2]
assert(len(B) == 0)

// ece: inverted → empty string
var B = S[4..1]
assert(len(B) == 0)


// ============================================================
// STRING SLICES — MULTIBYTE (the bug fix)
// Each character below is a 3-byte UTF-8 rune:
//   '日' '本' '語' 'テ' 'ス' 'ト'  → 6 runes, 18 bytes
// ============================================================

var S = "日本語テスト"

// Sanity: length should count runes, not bytes
assert(len(S) == 6)
assert(not(len(S) == 18))

// vcv: full copy
var B = S[..]
assert(B == "日本語テスト")
assert(len(B) == 6)

// vce: [:3] → first 3 runes
var B = S[..3]
assert(B == "日本語")
assert(len(B) == 3)

// ecv: [3:] → last 3 runes
var B = S[3..]
assert(B == "テスト")
assert(len(B) == 3)

// ece: [1..4] → middle 3 runes
var B = S[1..4]
assert(B == "本語テ")
assert(len(B) == 3)

// ece: negative indices wrap correctly on rune count
var B = S[-3..-1]
assert(B == "テス")
assert(len(B) == 2)

// ece: [0..1] → first rune only
var B = S[0..1]
assert(B == "日")
assert(not(B == "日本"))

// ecv: start at last rune
var B = S[5..]
assert(B == "ト")
assert(len(B) == 1)

// ece: out-of-range end clamps to rune length, not byte length
var B = S[4..99]
assert(B == "スト")
assert(not(len(B) == 99))

// ece: s > rune length → empty
var B = S[99..100]
assert(len(B) == 0)

// Mixed ASCII and multibyte: 'a' 'é' 'b' 'ü' 'c' → 5 runes
var S = "aébüc"
assert(len(S) == 5)

var B = S[1..3]
assert(B == "éb")
assert(len(B) == 2)

var B = S[..-1]
assert(B == "aébü")

var B = S[-2..]
assert(B == "üc")


// ============================================================
// BYTES SLICES
// ============================================================

var By = bytes.new([10, 20, 30, 40, 50])

// vcv
var B = By[..]
assert(len(B) == 5 and B[0] == 10 and B[4] == 50)

// vce
var B = By[..2]
assert(len(B) == 2 and B[0] == 10 and B[1] == 20)

// ecv
var B = By[3..]
assert(len(B) == 2 and B[0] == 40 and B[1] == 50)

// ece
var B = By[1..4]
assert(len(B) == 3 and B[0] == 20 and B[2] == 40)

// negative index wraps
var B = By[-2..]
assert(len(B) == 2 and B[0] == 40 and B[1] == 50)

// out-of-range end clamps
var B = By[3..99]
assert(len(B) == 2 and B[0] == 40)

// s == e → empty
var B = By[2..2]
assert(len(B) == 0)

// inverted → empty
var B = By[4..1]
assert(len(B) == 0)

// Independence: values with ref semantics are shallow copies
// values with value semantics are deep copies

var R = [{}]
var C = R[..]

C[0]["foo"] = "bar"

append(C, 42)

assert(not(R == C))
assert(R[0] == C[0])


R = [10, 20, 30, 40, 50]
C = R[0..3]
C[0] = 99
assert(R[0] == 10)
assert(not(C[0] == R[0]))




